{
  "name": "janus-dashboard",
  "version": "1.0.0",
  "description": "JANUS Dual-Agent Orchestration System - Web Dashboard",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "husky",
    "j": "tsx src/jules-cli.ts"
  },
  "keywords": [],
  "author": "Google Jules",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.12",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "fastmcp": "^3.33.0",
    "lucide-react": "^0.474.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netzkontrast/JANUS.git"
  },
  "bugs": {
    "url": "https://github.com/netzkontrast/JANUS/issues"
  },
  "homepage": "https://github.com/netzkontrast/JANUS#readme"
